# Claude API — get from console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# Google Sheets — base64-encoded service account JSON
# Create at console.cloud.google.com → Service Accounts
GOOGLE_SERVICE_ACCOUNT_JSON=base64encodedJSON

# Google Sheet IDs (from URL: /spreadsheets/d/<ID>/)
VEU_SHEET_ID=your_veu_google_sheet_id_here
SMSF_SHEET_ID=your_smsf_google_sheet_id_here

# Email notifications — get from resend.com
RESEND_API_KEY=re_...
NOTIFICATION_EMAIL=thomas.taresch@unwindai.com.au
